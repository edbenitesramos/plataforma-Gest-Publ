# Banco de dados
DATABASE_URL=postgresql://user:password@localhost:5432/ebr_platform
DB_USER=ebr_user
DB_PASSWORD=change_me_strong_password

# Redis
REDIS_URL=redis://:change_me@localhost:6379
REDIS_PASSWORD=change_me

# JWT (gerar com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=GERAR_COM_CRYPTO_RANDOMBYTES_64
JWT_REFRESH_SECRET=GERAR_COM_CRYPTO_RANDOMBYTES_64_DIFERENTE
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASS=sua_senha_de_app
EMAIL_FROM=noreply@ebrconsultoria.com.br

# URLs
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# APIs Públicas
# Portal da Transparência — solicitar em: https://portaldatransparencia.gov.br/api-de-dados/cadastrar
CGU_API_KEY=sua_chave_aqui

# Configurações
NODE_ENV=development
PORT=3001
LOG_LEVEL=info
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Lockout
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=30
